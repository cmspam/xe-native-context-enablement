@@ -0,0 +1,30 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ *
+ * Virtio-GPU transport for Xe ioctls in intel-media-driver (iHD).
+ * Embeds a vdrm client so iHD works on virtio-gpu without any shim.
+ */
+
+#ifndef MOS_XE_VIRTIO_H
+#define MOS_XE_VIRTIO_H
+
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdint.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+bool mos_xe_virtio_probe(int fd);
+int  mos_xe_virtio_init(int fd);
+void mos_xe_virtio_fini(int fd);
+bool mos_xe_virtio_is_active(int fd);
+int  mos_xe_ioctl(int fd, unsigned long request, void *arg);
+void *mos_xe_gem_mmap(int fd, uint32_t handle, size_t size);
+
+#ifdef __cplusplus
+}
+#endif
+#endif /* MOS_XE_VIRTIO_H */
