diff --git a/src/drm/xe/xe_object.c b/src/drm/xe/xe_object.c
new file mode 100644
index 00000000..9d1da490
--- /dev/null
+++ b/src/drm/xe/xe_object.c
@@ -0,0 +1,42 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#include <drm/xe_drm.h>
+
+#include "xe_object.h"
+
+struct xe_object *
+xe_object_create(uint32_t handle, uint64_t size, uint16_t cpu_caching)
+{
+   struct xe_object *obj = calloc(1, sizeof(*obj));
+
+   if (!obj)
+      return NULL;
+
+   obj->map_info = VIRGL_RENDERER_MAP_CACHE_CACHED;
+   obj->base.handle = handle;
+   obj->base.size = size;
+
+   switch (cpu_caching) {
+   case DRM_XE_GEM_CPU_CACHING_WC:
+      obj->map_info = VIRGL_RENDERER_MAP_CACHE_WC;
+      break;
+   case DRM_XE_GEM_CPU_CACHING_WB:
+   default:
+      obj->map_info = VIRGL_RENDERER_MAP_CACHE_CACHED;
+      break;
+   }
+
+   return obj;
+}
+
+void
+xe_renderer_free_object(struct drm_context *dctx, struct drm_object *dobj)
+{
+   struct drm_gem_close close = { .handle = dobj->handle };
+
+   drmIoctl(dctx->fd, DRM_IOCTL_GEM_CLOSE, &close);
+   free(dobj);
+}
